# Groq API key used by MarketGPT and other LLM-powered flows.
GROQ_API_KEY=

# Supabase project URL (https://<project>.supabase.co).
SUPABASE_URL=

# Supabase anonymous key for public client operations.
SUPABASE_ANON_KEY=

# Supabase service role key for server-side privileged operations.
SUPABASE_SERVICE_KEY=

# Application runtime environment. Use development or production.
APP_ENV=development

# Application semantic version shown in health and metadata responses.
APP_VERSION=1.0.0
